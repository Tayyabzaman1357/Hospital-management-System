rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return getUserData().role == 'admin';
    }
    
    // Helper function to check if user is doctor
    function isDoctor() {
      return getUserData().role == 'doctor';
    }
    
    // Helper function to check if user is receptionist
    function isReceptionist() {
      return getUserData().role == 'receptionist';
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Patients collection
    match /patients/{patientId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isAdmin() || isDoctor() || isReceptionist());
      allow update: if isAuthenticated() && (isAdmin() || isDoctor() || isReceptionist());
      allow delete: if isAuthenticated() && (isAdmin());
    }
    
    // Appointments collection
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isAdmin() || 
        isReceptionist() || 
        (isDoctor() && resource.data.doctorId == request.auth.uid)
      );
      allow delete: if isAuthenticated() && (isAdmin() || isReceptionist());
    }
    
    // Prescriptions collection
    match /prescriptions/{prescriptionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isAdmin() || isDoctor());
      allow update: if isAuthenticated() && (isAdmin() || isDoctor());
      allow delete: if isAdmin();
    }
    
    // Diagnosis logs collection
    match /diagnosisLogs/{logId} {
      allow read: if isAuthenticated() && (isAdmin() || isDoctor());
      allow create: if isAuthenticated() && (isAdmin() || isDoctor());
      allow update: if isDoctor() && resource.data.doctorId == request.auth.uid;
      allow delete: if isAdmin();
    }
    
    // Medical records collection (if needed in future)
    match /medicalRecords/{recordId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        isDoctor() || 
        isReceptionist()
      );
      allow create: if isAuthenticated() && (isAdmin() || isDoctor());
      allow update: if isAuthenticated() && (isAdmin() || isDoctor());
      allow delete: if isAdmin();
    }
  }
}
